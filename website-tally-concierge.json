    {
      "parameters": {
        "jsCode": "const geminiRes = $input.first().json;\nconst prev = $('Normalize Guest Request').first().json;\n\nlet parsed = {};\ntry {\n  const raw = geminiRes.candidates[0].content.parts[0].text;\n  const clean = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch(e) {\n  parsed = { intent: 'other', language: prev.language || 'en', summary: 'Unable to parse', urgency: 'low', is_booking_confirmation: false };\n}\n\nreturn [{\n  json: {\n    ...prev,\n    intent:               parsed.intent || 'other',\n    language:             parsed.language || prev.language || 'en',\n    summary:              parsed.summary || '',\n    urgency:              parsed.urgency || 'low',\n    isBookingConfirmation: parsed.is_booking_confirmation || false\n  }\n}];"
      },
