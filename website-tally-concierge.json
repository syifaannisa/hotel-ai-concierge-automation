{
  "name": "Hotel AI Concierge — Website and Tally Intake",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const body = $input.first().json;\n\nlet channel, guestName, guestPhone, guestEmail, guestMessage, language, extraData;\n\n// ---- TALLY / WEB FORM ----\nif (body.data && body.data.fields) {\n  const fields = body.data.fields;\n  const get = (label) => (fields.find(f => f.label === label) || {}).value || '';\n\n  guestName    = get('Full Name');\n  guestPhone   = get('WhatsApp Number') || get('Phone Number') || '';\n  guestEmail   = get('Email Address') || get('Email') || '';\n  language     = (get('Preferred Language') || 'English').toLowerCase().slice(0, 2);\n  const intent = get('What can we help you with?') || '';\n  const checkin  = get('Check-in Date') || '';\n  const checkout = get('Check-out Date') || '';\n  const roomPref = get('Room Type Preference') || '';\n  const guests   = get('Number of Guests') || '';\n  const msg      = get('Your Message / Request') || '';\n  guestMessage = `[${intent}] ${msg}` + (checkin ? ` | Check-in: ${checkin}, Check-out: ${checkout}, Room: ${roomPref}, Guests: ${guests}` : '');\n  extraData = { checkin, checkout, roomPref, guests, intentFromForm: intent };\n  channel = guestEmail ? 'email' : 'web';\n\n// ---- TELEGRAM ----\n} else if (body.message && body.message.chat) {\n  const msg = body.message;\n  channel      = 'telegram';\n  guestName    = (msg.from.first_name || '') + ' ' + (msg.from.last_name || '');\n  guestPhone   = String(msg.chat.id);\n  guestEmail   = '';\n  guestMessage = msg.text || '';\n  language     = 'en';\n  extraData    = { telegramChatId: msg.chat.id, telegramUsername: msg.from.username || '' };\n\n// ---- TWILIO SMS ----\n} else if (body.From && body.Body && body.To) {\n  channel      = 'sms';\n  guestName    = body.ProfileName || 'Guest';\n  guestPhone   = body.From;\n  guestEmail   = '';\n  guestMessage = body.Body;\n  language     = 'en';\n  extraData    = { twilioSid: body.SmsSid || '' };\n\n// ---- EMAIL ----\n} else if (body.from_email || body.sender || (body.headers && body.headers.from)) {\n  const from = body.from_email || body.sender || body.headers.from || '';\n  channel      = 'email';\n  guestName    = body.from_name || body.name || from.split('@')[0] || 'Guest';\n  guestPhone   = body.phone || '';\n  guestEmail   = from;\n  guestMessage = body.text || body.body || body.stripped_text || '';\n  language     = 'en';\n  extraData    = { subject: body.subject || 'Guest inquiry', replyTo: from };\n\n// ---- WHATSAPP ----\n} else if (body.entry && body.entry[0] && body.entry[0].changes) {\n  const change  = body.entry[0].changes[0].value;\n  const msgObj  = change.messages ? change.messages[0] : {};\n  const contact = change.contacts ? change.contacts[0] : {};\n  channel      = 'whatsapp';\n  guestName    = contact.profile ? contact.profile.name : 'Guest';\n  guestPhone   = msgObj.from || '';\n  guestEmail   = '';\n  guestMessage = msgObj.text ? msgObj.text.body : '';\n  language     = 'en';\n  extraData    = { waMessageId: msgObj.id || '', phoneNumberId: change.metadata ? change.metadata.phone_number_id : '' };\n\n// ---- FALLBACK ----\n} else {\n  channel      = body.channel || 'web';\n  guestName    = body.guestName || body.name || 'Test Guest';\n  guestPhone   = body.guestPhone || body.phone || '';\n  guestEmail   = body.guestEmail || body.email || '';\n  guestMessage = body.guestMessage || body.message || body.text || 'Hello';\n  language     = body.language || 'en';\n  extraData    = {};\n}\n\nreturn [{\n  json: {\n    channel,\n    guestName:    guestName.trim(),\n    guestPhone,\n    guestEmail,\n    guestMessage,\n    language,\n    extraData,\n    hotelCode:   'HTL001',\n    hotelName:   'Hotel Adriatica',\n    timestamp:   new Date().toISOString(),\n    sessionId:   (guestPhone || guestEmail || 'anon') + '_' + Date.now()\n  }\n}];"
      },
      "id": "1ea0f15a-51c9-45e9-bbce-59cd51752ab3",
      "name": "Normalize Guest Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -4672,
        -32
