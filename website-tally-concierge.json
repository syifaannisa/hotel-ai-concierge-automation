        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"From\": \"concierge@adriatica-hotel.com\",\n  \"To\": \"{{ $json.guestEmail }}\",\n  \"Subject\": \"✅ Booking Confirmation — Hotel Adriatica\",\n  \"HtmlBody\": \"<html><body style='font-family:Georgia,serif;max-width:600px;margin:auto;padding:30px'><div style='text-align:center;margin-bottom:20px'><h1 style='color:#2c5f2e;font-size:24px'>Hotel Adriatica</h1><p style='color:#888;font-style:italic'>Where the sea meets serenity</p></div><hr style='border:1px solid #eee'/><h2 style='color:#333'>Booking Confirmation</h2><p>Dear {{ $json.guestName }},</p><p>Thank you for choosing <strong>Hotel Adriatica</strong>. We are delighted to confirm your reservation.</p><table style='width:100%;border-collapse:collapse;margin:20px 0'><tr style='background:#f8f4f0'><td style='padding:10px;border:1px solid #ddd'><strong>Guest</strong></td><td style='padding:10px;border:1px solid #ddd'>{{ $json.guestName }}</td></tr><tr><td style='padding:10px;border:1px solid #ddd'><strong>Room</strong></td><td style='padding:10px;border:1px solid #ddd'>{{ $json.extraData.roomPref || 'As requested' }}</td></tr><tr style='background:#f8f4f0'><td style='padding:10px;border:1px solid #ddd'><strong>Check-in</strong></td><td style='padding:10px;border:1px solid #ddd'>{{ $json.extraData.checkin || 'To be confirmed' }} at 14:00</td></tr><tr><td style='padding:10px;border:1px solid #ddd'><strong>Checkout</strong></td><td style='padding:10px;border:1px solid #ddd'>{{ $json.extraData.checkout || 'To be confirmed' }} at 11:00</td></tr><tr style='background:#f8f4f0'><td style='padding:10px;border:1px solid #ddd'><strong>Guests</strong></td><td style='padding:10px;border:1px solid #ddd'>{{ $json.extraData.guests || '—' }}</td></tr></table><p>A pre-authorization of €200 will be applied at check-in. Free cancellation up to 48 hours before arrival.</p><p>WiFi: <strong>ADRIATICA_GUEST</strong> | Password: <strong>SeaBreeze2024</strong></p><p>Need anything? Reply to this email or WhatsApp us at <strong>+355 22 123 456</strong>.</p><hr style='border:1px solid #eee;margin-top:30px'/><p style='color:#888;font-size:12px;text-align:center'>Hotel Adriatica · Lungomare Via Nazionale 12, Shkodër, Albania · concierge@adriatica-hotel.com</p></body></html>\",\n  \"MessageStream\": \"outbound\"\n}",
        "options": {}
