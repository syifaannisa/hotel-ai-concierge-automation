      "parameters": {
        "jsCode": "// Merge context: data from intent + PMS response (if any)\nconst ctx = $('Parse Intent Classification').first().json;\n\n// Try to get PMS data if it ran\nlet pmsData = {};\ntry { pmsData = $('PMS — Check Availability').first().json; } catch(e) {}\ntry { pmsData = $('PMS — Room Service Simulation').first().json; } catch(e) {}\n\nreturn [{ json: { ...ctx, pmsData } }];"
